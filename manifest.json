{
  "manifest_version": 3,
  "name": "Job Tracker",
  "version": "1.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.naukri.com/*"
  ],
  "background":{
      "service_worker":"background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.naukri.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "action":{
      "default_popup":"popup.html"
  }
}
 